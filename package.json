        "clean-webpack-plugin": "^0.1.19",
        "cross-env": "^5.2.0",
        "cypress": "^3.4.0",
        "datatables": "^1.10.18",
        "detector-webgl": "^2.0.0",
        "font-awesome": "^4.7.0",
        "jquery": "^3.2",
        "jquery-ui": "^1.12.1",
        "laravel-mix": "^2.0.1",
        "lodash": "^4.17.11",
        "popper.js": "^1.14.5",
        "three": "^0.94.0",
        "three-objmtll-loader": "^1.0.1",
        "vue": "^2.5.17"
    },
